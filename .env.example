# ── Model ──
MODEL_ID=black-forest-labs/FLUX.1-schnell
DEVICE=cuda
DTYPE=float8_e4m3fn

# ── Generation defaults ──
DEFAULT_NUM_STEPS=4
DEFAULT_GUIDANCE_SCALE=0.0
MAX_RESOLUTION=2048

# ── Storage ──
STORAGE_DIR=./output

# ── Queue ──
MAX_QUEUE_SIZE=10000

# ── Server ──
HOST=0.0.0.0
PORT=8000

# ── Torch compile (set to false to skip warm-up on startup) ──
ENABLE_TORCH_COMPILE=true
